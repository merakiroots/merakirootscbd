# EditorConfig for WordPress/PHP Development
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{php,html,js,css,json,md,txt}]
indent_size = 4

[*.php]
indent_size = 4

[*.md]
indent_size = 4
trim_trailing_whitespace = false

[*.yml,yaml]
indent_size = 2

[*.xml]
indent_size = 4

[*.sql]
indent_size = 4

[Makefile]
indent_style = tab

[Dockerfile*]
indent_size = 4

[package.json]
indent_size = 4

[composer.json,composer.lock]
indent_size = 4
