{
    "name": "my-theme",
    "version": "1.0.0",
    "description": "My WordPress theme",
    "main": "index.js",
    "scripts": {
        "build": "npm run build:css && npm run build:js",
        "build:css": "sass src/scss/style.scss dist/css/style.css --style compressed",
        "build:js": "webpack --config webpack.config.js",
        "watch": "npm run watch:css && npm run watch:js",
        "watch:css": "sass --watch src/scss/style.scss dist/css/style.css",
        "watch:js": "webpack --watch --config webpack.config.js"
    },
    "scripts": {
        "build": "wp-scripts build",
        "check-engines": "wp-scripts check-engines",
        "check-licenses": "wp-scripts check-licenses",
        "format": "wp-scripts format",
        "lint:css": "wp-scripts lint-style",
        "lint:js": "wp-scripts lint-js",
        "lint:md:docs": "wp-scripts lint-md-docs",
        "lint:pkg-json": "wp-scripts lint-pkg-json",
        "packages-update": "wp-scripts packages-update",
        "plugin-zip": "wp-scripts plugin-zip",
        "start": "wp-scripts start",
        "test:e2e": "wp-scripts test-e2e",
        "test:unit": "wp-scripts test-unit-js"
    },
    "author": "Your Name",
    "license": "MIT",
    "dependencies": {
        "sass": "^1.77.8"
    },
    "devDependencies": {
        "@babel/core": "^7.24.8",
        "@babel/preset-env": "^7.24.8",
        "babel-loader": "^9.1.3",
        "webpack": "^5.93.0",
        "webpack-cli": "^5.1.4",
        "wordpress/wordpress": "^6.9",
        "wordpress/wp-cli": "^2.7.1",
        "woocommerce/woocommerce": ""
    }
}
