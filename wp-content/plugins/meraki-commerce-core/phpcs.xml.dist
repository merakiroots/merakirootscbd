<?xml version="1.0"?>
<ruleset name="Meraki Commerce Core">
	<description>WordPress Coding Standards tuned for the plugin's PSR-4 source layout.</description>

	<arg name="extensions" value="php"/>
	<arg name="warning-severity" value="0"/>

	<file>meraki-commerce-core.php</file>
	<file>uninstall.php</file>
	<file>src</file>

	<exclude-pattern>vendor/*</exclude-pattern>

	<rule ref="WordPress">
		<exclude name="WordPress.Files.FileName"/>
	</rule>
</ruleset>
