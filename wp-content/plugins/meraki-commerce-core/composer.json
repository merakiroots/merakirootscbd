{
    "name": "merakirootscbd2/meraki-commerce-core",
    "description": "Product trust metadata, COA records, and lab-results rendering for Meraki Roots WooCommerce store",
    "type": "wordpress-plugin",
    "license": "proprietary",
    "autoload": {
        "psr-4": {
            "MerakiCommerceCore\\": "src/"
        }
    },
    "require": {
        "php": ">=8.3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "squizlabs/php_codesniffer": "^3.10",
        "wp-coding-standards/wpcs": "^3.1",
        "phpstan/phpstan": "^1.12",
        "szepeviktor/phpstan-wordpress": "^1.3",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "platform": {
            "php": "8.3.0"
        }
    },
    "scripts": {
        "lint": "phpcs",
        "fix": "phpcbf",
        "analyse": "phpstan analyse"
    }
}
