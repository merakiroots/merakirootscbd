{
    "name": "merakirootscbd2/plugin",
    "description": "Local WordPress/WooCommerce plugin.",
    "type": "wordpress-plugin",
    "license": "proprietary",
    "autoload": {
        "psr-4": {
            "Local\\MyPlugin\\": "src/"
        }
    },
    "require": {
        "php": ">=8.3",
        "composer/ca-bundle": "^1.3.4",
        "wp-cli/wp-cli-bundle": "*",
        "wp-cli/wp-cli": "^2.12",
        "woocommerce/wc-smooth-generator": "^5.9",
        "woocommerce/woocommerce-sniffs": "^1.0",
        "wordpress/wp-cli": "^2.12.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "squizlabs/php_codesniffer": "^3.10",
        "wp-coding-standards/wpcs": "^3.1",
        "phpstan/phpstan": "^1.12",
        "szepeviktor/phpstan-wordpress": "^1.3",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0"
    },
    "config": {
        "disable-tls": false,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "platform": {
            "php": "8.3.1"
        }
    },
    "scripts": {
        "lint": "phpcs .",
        "fix": "phpcbf .",
        "analyse": "phpstan analyse src --level=5"
    }
}
