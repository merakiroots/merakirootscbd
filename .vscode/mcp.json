{
    "servers": {
        "io.github.ChromeDevTools/chrome-devtools-mcp": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "--registry",
                "https://registry.npmjs.org",
                "chrome-devtools-mcp@0.25.0"
            ],
            "gallery": "https://api.mcp.github.com",
            "version": "0.25.0"
        },
        "io.github.upstash/context7": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "@upstash/context7-mcp@1.0.31"
            ],
            "env": {
                "CONTEXT7_API_KEY": "${input:CONTEXT7_API_KEY=ctx7sk-675059aa-c144-428e-9e24-be56c10c00a7}"
            },
            "gallery": "https://api.mcp.github.com",
            "version": "1.0.31"
        },
        "io.github.github/github-mcp-server": {
            "type": "stdio",
            "command": "docker",
            "args": [
                "run",
                "-i",
                "--rm",
                "-e",
                "GITHUB_PERSONAL_ACCESS_TOKEN=${input:token=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx}",
                "ghcr.io/github/github-mcp-server:1.0.4"
            ],
            "gallery": "https://api.mcp.github.com",
            "version": "1.0.4"
        }
    },
    "inputs": [
        {
            "id": "CONTEXT7_API_KEY=ctx7sk-675059aa-c144-428e-9e24-be56c10c00a7",
            "type": "promptString",
            "description": "API key for authentication",
            "password": true
        },
        {
            "id": "token=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
            "type": "promptString",
            "description": "GitHub personal access token",
            "password": true
        }
    ]
}